# Сервер порты (default: 3001)
PORT=3001

# JWT қауіпсіздік кілті — өзгертіңіз!
JWT_SECRET=moldyr_olen_super_secret_key_change_me

# SQLite дерекқорының жолы (default: ./moldyr.db)
DB_PATH=./moldyr.db

# Frontend домені (CORS үшін)
# Development: http://localhost:3000
# Production: https://yoursite.com
FRONTEND_ORIGIN=*
